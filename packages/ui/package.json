{
  "name": "@connor-adams/designsystem",
  "version": "0.1.0",
  "description": "Connor Adams design system — React components built on @connor-adams/tokens.",
  "license": "SEE LICENSE FILE",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/connor-adams/cashflow-design-system.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/connor-adams/cashflow-design-system#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "sideEffects": ["*.css"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./styles.css"
  },
  "files": ["dist", "styles.css"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@connor-adams/tokens": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  }
}
